rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isLoggedIn() { return request.auth != null; }
    function isAdmin() {
      return isLoggedIn() &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin';
    }
    match /colecta/{docId}  { allow read: if isLoggedIn(); allow write: if isAdmin(); }
    match /pagos/{pagoId}   { allow read: if isLoggedIn(); allow write: if false; }
    match /retiros/{id}     { allow read: if isLoggedIn(); allow write: if isAdmin(); }
    match /usuarios/{uid}   { allow read: if request.auth.uid == uid || isAdmin(); allow write: if false; }
  }
}
